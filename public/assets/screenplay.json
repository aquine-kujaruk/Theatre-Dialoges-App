[
  {
    "id": 0,
    "speaker": "Peggy",
    "start": 0.1,
    "end": 2.88,
    "text": " All right, children, we're ready."
  },
  {
    "id": 1,
    "speaker": "Peggy",
    "start": 3.82,
    "end": 8.08,
    "text": " Children, children, children, this is a dining room."
  },
  {
    "id": 2,
    "speaker": "Peggy",
    "start": 8.7,
    "end": 10.74,
    "text": " This is not the monkey house at the zoo."
  },
  {
    "id": 3,
    "speaker": "Peggy",
    "start": 12.36,
    "end": 12.96,
    "text": " All right, then."
  },
  {
    "id": 4,
    "speaker": "Peggy",
    "start": 13.92,
    "end": 18.3,
    "text": " I'll just have to tell Roberta in the kitchen to put away all the ice cream and cake."
  },
  {
    "id": 5,
    "speaker": "Peggy",
    "start": 19.7,
    "end": 21.82,
    "text": " Good, that's much better."
  },
  {
    "id": 6,
    "speaker": "Peggy",
    "start": 23.26,
    "end": 28.18,
    "text": " Now I want everyone to leave the table quietly, quietly,"
  },
  {
    "id": 7,
    "speaker": "Peggy",
    "start": 28.34,
    "end": 33.52,
    "text": " and go into the hall and then come back in here in the right way."
  },
  {
    "id": 8,
    "speaker": "Peggy",
    "start": 34.64,
    "end": 35.62,
    "text": " That's it."
  },
  {
    "id": 9,
    "speaker": "Peggy",
    "start": 35.98,
    "end": 39.24,
    "text": " Go out, turn around, and come in."
  },
  {
    "id": 10,
    "speaker": "Peggy",
    "start": 40.32,
    "end": 44.5,
    "text": " Come in as if you were your mummies and daddies coming into a lovely dinner party."
  },
  {
    "id": 11,
    "speaker": "Peggy",
    "start": 45.8,
    "end": 50.8,
    "text": " No, no, let Winky go first, since it's her birthday and she's the hostess."
  },
  {
    "id": 12,
    "speaker": "Peggy",
    "start": 51.82,
    "end": 52.38,
    "text": " That's it."
  },
  {
    "id": 13,
    "speaker": "Peggy",
    "start": 53.3,
    "end": 54.54,
    "text": " Good, good."
  },
  {
    "id": 14,
    "speaker": "Peggy",
    "start": 55.34,
    "end": 57.1,
    "text": " You sit at the head of the table, Winky."
  },
  {
    "id": 15,
    "speaker": "Peggy",
    "start": 58.3,
    "end": 67.66,
    "text": " Good. No, no, Billy, you sit next to Winky. It should be boy-girl, boy-girl. That's it?"
  },
  {
    "id": 16,
    "speaker": "Peggy",
    "start": 68.12,
    "end": 73,
    "text": " Yes, very good. Now, what do we do with our napkins?"
  },
  {
    "id": 17,
    "speaker": "Peggy",
    "start": 73.98,
    "end": 80.94,
    "text": " Yes, exactly. We unfold them and tuck them under our chins. And then we put on our party hats."
  },
  {
    "id": 18,
    "speaker": "Brewster",
    "start": 82.12,
    "end": 85.56,
    "text": " Can the boys wear their hats in the house?"
  },
  {
    "id": 19,
    "speaker": "Peggy",
    "start": 86.2,
    "end": 90.4,
    "text": " Yes, they can, Brewster, because this is a special occasion."
  },
  {
    "id": 20,
    "speaker": "Peggy",
    "start": 90.72,
    "end": 94.26,
    "text": " And sometimes on special occasions, the rules can change."
  },
  {
    "id": 21,
    "speaker": "Peggy",
    "start": 95.3,
    "end": 96.14,
    "text": " I said sometimes."
  },
  {
    "id": 22,
    "speaker": "Peggy",
    "start": 97.18,
    "end": 99.66,
    "text": " And I meant some of the rules."
  },
  {
    "id": 23,
    "speaker": "Billy",
    "start": 101.18,
    "end": 102.08,
    "text": " There's my daddy."
  },
  {
    "id": 24,
    "speaker": "Peggy",
    "start": 102.88,
    "end": 103.8,
    "text": " Where, Billy?"
  },
  {
    "id": 25,
    "speaker": "Peggy",
    "start": 104.26,
    "end": 105.88,
    "text": " Oh, hi."
  },
  {
    "id": 26,
    "speaker": "Ted",
    "start": 106.14,
    "end": 106.96,
    "text": " Hi."
  },
  {
    "id": 27,
    "speaker": "Peggy",
    "start": 107.36,
    "end": 108.66,
    "text": " What brings you here?"
  },
  {
    "id": 28,
    "speaker": "Ted",
    "start": 109.18,
    "end": 110.5,
    "text": " Have to pick up Bill."
  },
  {
    "id": 29,
    "speaker": "Peggy",
    "start": 110.96,
    "end": 113.06,
    "text": " I thought Judy was picking him up."
  },
  {
    "id": 30,
    "speaker": "Ted",
    "start": 114.02,
    "end": 115.02,
    "text": " She asked me to."
  },
  {
    "id": 31,
    "speaker": "Peggy",
    "start": 116.14,
    "end": 119.02,
    "text": " You're a little early. We haven't even had our cake."
  },
  {
    "id": 32,
    "speaker": "Ted",
    "start": 119.96,
    "end": 121.43,
    "text": " She told me to be early."
  },
  {
    "id": 33,
    "speaker": "Sandra",
    "start": 122.03,
    "end": 123.65,
    "text": " I can't get mine to work."
  },
  {
    "id": 34,
    "speaker": "Peggy",
    "start": 124.81,
    "end": 128.15,
    "text": " Help her, Brewster. Little boys are supposed to help little girls."
  },
  {
    "id": 35,
    "speaker": "Ted",
    "start": 129.47224,
    "end": 130.47224,
    "text": " Where's Frank?"
  },
  {
    "id": 36,
    "speaker": "Peggy",
    "start": 131.09224,
    "end": 133.71225,
    "text": " Playing golf. Where else?"
  },
  {
    "id": 37,
    "speaker": "Ted",
    "start": 134.23224,
    "end": 135.11224,
    "text": " On Winky's birthday?"
  },
  {
    "id": 38,
    "speaker": "Peggy",
    "start": 136.23224,
    "end": 138.25224,
    "text": " Don't get me started. Please."
  },
  {
    "id": 39,
    "speaker": "Winkie",
    "start": 139.59224,
    "end": 141.89224,
    "text": " Can we have the ice cream now, please?"
  },
  {
    "id": 40,
    "speaker": "Peggy",
    "start": 143.09224,
    "end": 145.35225,
    "text": " In a minute, dear. Be patient."
  },
  {
    "id": 41,
    "speaker": "Peggy",
    "start": 145.81224,
    "end": 148.09225,
    "text": " Then you'll have something to look forward to."
  },
  {
    "id": 42,
    "speaker": "Ted",
    "start": 148.77225,
    "end": 150.59225,
    "text": " Judy must have known he'd be playing golf."
  },
  {
    "id": 43,
    "speaker": "Peggy",
    "start": 151.79224,
    "end": 152.99225,
    "text": " Judy knows everything."
  },
  {
    "id": 44,
    "speaker": "Ted",
    "start": 154.31224,
    "end": 155.99225,
    "text": " She knows about us, at least."
  },
  {
    "id": 45,
    "speaker": "Peggy",
    "start": 157.07225,
    "end": 158.33224,
    "text": " About us?"
  },
  {
    "id": 46,
    "speaker": "Peggy",
    "start": 158.95224,
    "end": 159.75224,
    "text": " How?"
  },
  {
    "id": 47,
    "speaker": "Ted",
    "start": 160.37225,
    "end": 162.29224,
    "text": " She said she could tell by the way we behaved."
  },
  {
    "id": 48,
    "speaker": "Peggy",
    "start": 163.53224,
    "end": 164.37225,
    "text": " Behaved?"
  },
  {
    "id": 49,
    "speaker": "Peggy",
    "start": 165.13225,
    "end": 165.89224,
    "text": " Where?"
  },
  {
    "id": 50,
    "speaker": "Ted",
    "start": 166.53224,
    "end": 167.95224,
    "text": " At the Bramwell's dinner party."
  },
  {
    "id": 51,
    "speaker": "Peggy",
    "start": 169.13225,
    "end": 170.61224,
    "text": " We hardly spoke to each other."
  },
  {
    "id": 52,
    "speaker": "Ted",
    "start": 171.77225,
    "end": 172.69225,
    "text": " That's how she could tell."
  },
  {
    "id": 53,
    "speaker": "Peggy",
    "start": 173.89224,
    "end": 175.19225,
    "text": " They want ice cream."
  },
  {
    "id": 54,
    "speaker": "Ted",
    "start": 175.85225,
    "end": 178.35225,
    "text": " She said she'll fight it, tooth and nail."
  },
  {
    "id": 55,
    "speaker": "Peggy",
    "start": 179.03224,
    "end": 180.13225,
    "text": " Fight what?"
  },
  {
    "id": 56,
    "speaker": "Peggy",
    "start": 180.55225,
    "end": 181.57224,
    "text": " We haven't done anything."
  },
  {
    "id": 57,
    "speaker": "Ted",
    "start": 182.81226,
    "end": 184.55225,
    "text": " She wants to nip it in the bud."
  },
  {
    "id": 58,
    "speaker": "Peggy",
    "start": 185.21225,
    "end": 187.59225,
    "text": " All right, children, you win."
  },
  {
    "id": 59,
    "speaker": "Peggy",
    "start": 187.95224,
    "end": 189.84224,
    "text": " Now, Roberta is very busy in the kitchen"
  },
  {
    "id": 60,
    "speaker": "Peggy",
    "start": 189.84224,
    "end": 192.17224,
    "text": " because she also has a dinner party tonight."
  },
  {
    "id": 61,
    "speaker": "Peggy",
    "start": 193.01224,
    "end": 195.55225,
    "text": " So who would like to help bring things out?"
  },
  {
    "id": 62,
    "speaker": "Peggy",
    "start": 196.07224,
    "end": 197.63225,
    "text": " All right, tell you what."
  },
  {
    "id": 63,
    "speaker": "Peggy",
    "start": 198.33224,
    "end": 200.16225,
    "text": " Billy, you get the ice cream,"
  },
  {
    "id": 64,
    "speaker": "Peggy",
    "start": 200.16225,
    "end": 202.65225,
    "text": " and Sandra, you bring out the cake."
  },
  {
    "id": 65,
    "speaker": "Peggy",
    "start": 203.11224,
    "end": 205.43225,
    "text": " Careful, careful, walk, don't run."
  },
  {
    "id": 66,
    "speaker": "Peggy",
    "start": 206.39224,
    "end": 209.69225,
    "text": " And be polite to Roberta because she's working very hard."
  },
  {
    "id": 67,
    "speaker": "Peggy",
    "start": 210.07224,
    "end": 213.37225,
    "text": " And Brewster and Winky, you'll have other responsibilities."
  },
  {
    "id": 68,
    "speaker": "Peggy",
    "start": 214.61224,
    "end": 219.07224,
    "text": " For instance, Brewster, when Billy and Sandra reappear through that door,"
  },
  {
    "id": 69,
    "speaker": "Peggy",
    "start": 219.33224,
    "end": 219.99225,
    "text": " what will you do?"
  },
  {
    "id": 70,
    "speaker": "Brewster",
    "start": 221.07224,
    "end": 222.15225,
    "text": " Sing the song."
  },
  {
    "id": 71,
    "speaker": "Peggy",
    "start": 222.91225,
    "end": 223.49225,
    "text": " Good, Brewster."
  },
  {
    "id": 72,
    "speaker": "Peggy",
    "start": 224.25224,
    "end": 227.19225,
    "text": " Now be very quiet and watch that door."
  },
  {
    "id": 73,
    "speaker": "Peggy",
    "start": 227.29224,
    "end": 229.71225,
    "text": " And as soon as they come out, start singing."
  },
  {
    "id": 74,
    "speaker": "Peggy",
    "start": 231.03226,
    "end": 233.03226,
    "text": " So, what do we do?"
  },
  {
    "id": 75,
    "speaker": "Ted",
    "start": 233.69,
    "end": 235.93,
    "text": " She says she's thinking of telling her father about us."
  },
  {
    "id": 76,
    "speaker": "Peggy",
    "start": 236.89,
    "end": 237.93,
    "text": " Her father?"
  },
  {
    "id": 77,
    "speaker": "Ted",
    "start": 238.61,
    "end": 240.27,
    "text": " He'd fire me. Immediately."
  },
  {
    "id": 78,
    "speaker": "Peggy",
    "start": 241.67,
    "end": 242.92,
    "text": " What if he did?"
  },
  {
    "id": 79,
    "speaker": "Ted",
    "start": 243.48,
    "end": 244.76,
    "text": " I'd be out of a job, Peggy."
  },
  {
    "id": 80,
    "speaker": "Peggy",
    "start": 245.72,
    "end": 246.54,
    "text": " You could get another."
  },
  {
    "id": 81,
    "speaker": "Ted",
    "start": 247.80449,
    "end": 249.4645,
    "text": " Where? Doing what?"
  },
  {
    "id": 82,
    "speaker": "Peggy",
    "start": 250.0445,
    "end": 253.2645,
    "text": " No, no, sweetheart. Wait. Always wait."
  },
  {
    "id": 83,
    "speaker": "Peggy",
    "start": 254.4245,
    "end": 257.18448,
    "text": " Before you blow out the candles, you have to make a wish."
  },
  {
    "id": 84,
    "speaker": "Peggy",
    "start": 258.34448,
    "end": 260.1445,
    "text": " And Mommy has to make a wish."
  },
  {
    "id": 85,
    "speaker": "Peggy",
    "start": 260.7245,
    "end": 264.1045,
    "text": " See? Mommy is putting her wedding ring around one of the candles."
  },
  {
    "id": 86,
    "speaker": "Peggy",
    "start": 265.5245,
    "end": 268.5845,
    "text": " Now we both close our eyes and make a wish."
  },
  {
    "id": 87,
    "speaker": "Winkie",
    "start": 269.18448,
    "end": 270.6545,
    "text": " I wish I could have..."
  },
  {
    "id": 88,
    "speaker": "Peggy",
    "start": 270.6545,
    "end": 273.3245,
    "text": " No, no, don't tell."
  },
  {
    "id": 89,
    "speaker": "Peggy",
    "start": 273.8045,
    "end": 275.40448,
    "text": " Never tell a wish."
  },
  {
    "id": 90,
    "speaker": "Peggy",
    "start": 275.9445,
    "end": 277.8045,
    "text": " If you do, it won't come true."
  },
  {
    "id": 91,
    "speaker": "Peggy",
    "start": 279.2045,
    "end": 280.8645,
    "text": " All right, now blow."
  },
  {
    "id": 92,
    "speaker": "Peggy",
    "start": 282.1045,
    "end": 285.2645,
    "text": " Now, Winky, would you cut the cake and give everyone a piece, please?"
  },
  {
    "id": 93,
    "speaker": "Peggy",
    "start": 286.06448,
    "end": 288.1045,
    "text": " And Brewster, you pass the ice cream."
  },
  {
    "id": 94,
    "speaker": "Ted",
    "start": 289.40448,
    "end": 290.2445,
    "text": " What did you wish for?"
  },
  {
    "id": 95,
    "speaker": "Peggy",
    "start": 291.40448,
    "end": 291.96448,
    "text": " Won't tell."
  },
  {
    "id": 96,
    "speaker": "Ted",
    "start": 293.0845,
    "end": 294.68448,
    "text": " Do you think it will come true?"
  },
  {
    "id": 97,
    "speaker": "Peggy",
    "start": 295.46448,
    "end": 296.12448,
    "text": " No."
  },
  {
    "id": 98,
    "speaker": "Ted",
    "start": 297.12448,
    "end": 298.3845,
    "text": " She'd make it so messy."
  },
  {
    "id": 99,
    "speaker": "Ted",
    "start": 299.4245,
    "end": 300.0445,
    "text": " For everyone."
  },
  {
    "id": 100,
    "speaker": "Peggy",
    "start": 301.3845,
    "end": 302.1845,
    "text": " Judy."
  },
  {
    "id": 101,
    "speaker": "Ted",
    "start": 303.02448,
    "end": 303.96448,
    "text": " She'd make it impossible."
  },
  {
    "id": 102,
    "speaker": "Peggy",
    "start": 305.4845,
    "end": 306.8045,
    "text": " So would Frank."
  },
  {
    "id": 103,
    "speaker": "Ted",
    "start": 307.4845,
    "end": 309.1645,
    "text": " I thought he didn't care."
  },
  {
    "id": 104,
    "speaker": "Peggy",
    "start": 310.52448,
    "end": 312.46448,
    "text": " He'd care if it were messy."
  },
  {
    "id": 105,
    "speaker": "Ted",
    "start": 313.96448,
    "end": 316.2445,
    "text": " We could leave town."
  },
  {
    "id": 106,
    "speaker": "Peggy",
    "start": 317.62448,
    "end": 318.9445,
    "text": " And go where?"
  },
  {
    "id": 107,
    "speaker": "Ted",
    "start": 319.90448,
    "end": 321.7445,
    "text": " Wherever I find another job."
  },
  {
    "id": 108,
    "speaker": "Peggy",
    "start": 322.62448,
    "end": 322.96448,
    "text": " Yes."
  },
  {
    "id": 109,
    "speaker": "Ted",
    "start": 324.3245,
    "end": 326.2245,
    "text": " I've got an uncle in Syracuse."
  },
  {
    "id": 110,
    "speaker": "Peggy",
    "start": 327.4845,
    "end": 328.1845,
    "text": " Syracuse?"
  },
  {
    "id": 111,
    "speaker": "Ted",
    "start": 329.46448,
    "end": 331.4445,
    "text": " We could live there."
  },
  {
    "id": 112,
    "speaker": "Peggy",
    "start": 332.6845,
    "end": 335.5445,
    "text": " Is it nice, Syracuse?"
  },
  {
    "id": 113,
    "speaker": "Ted",
    "start": 336.7245,
    "end": 338.8045,
    "text": " I think it's on some lake."
  },
  {
    "id": 114,
    "speaker": "Peggy",
    "start": 340.4245,
    "end": 341.2445,
    "text": " Syracuse."
  },
  {
    "id": 115,
    "speaker": "Ted",
    "start": 342.8045,
    "end": 343.90448,
    "text": " You'd have Winky."
  },
  {
    "id": 116,
    "speaker": "Ted",
    "start": 344.34448,
    "end": 345.3645,
    "text": " I'd get Bill in the summer."
  },
  {
    "id": 117,
    "speaker": "Peggy",
    "start": 346.8045,
    "end": 347.62448,
    "text": " In Syracuse."
  },
  {
    "id": 118,
    "speaker": "Ted",
    "start": 347.62448,
    "end": 351.5045,
    "text": " At least we'd be free."
  },
  {
    "id": 119,
    "speaker": "Peggy",
    "start": 352.8645,
    "end": 354.7645,
    "text": " Winky, wipe your mouth please."
  },
  {
    "id": 120,
    "speaker": "Ted",
    "start": 356.04,
    "end": 357.30,
    "text": " Billy."
  },
  {
    "id": 121,
    "speaker": "Billy",
    "start": 357.30,
    "end": 359.00,
    "text": " What?"
  },
  {
    "id": 122,
    "speaker": "Ted",
    "start": 359.00,
    "end": 361.46,
    "text": " Would you come here a minute, please?"
  },
  {
    "id": 123,
    "speaker": "Ted",
    "start": 362.58,
    "end": 365.32,
    "text": " Do you have to go the bathroom?"
  },
  {
    "id": 124,
    "speaker": "Billy",
    "start": 365.90,
    "end": 366.64,
    "text": " No."
  },
  {
    "id": 125,
    "speaker": "Ted",
    "start": 367.37674,
    "end": 369.91672,
    "text": " Then don't do that, please."
  },
  {
    "id": 126,
    "speaker": "Billy",
    "start": 370.43674,
    "end": 372.79672,
    "text": " Don't do what?"
  },
  {
    "id": 127,
    "speaker": "Ted",
    "start": 373.59674,
    "end": 374.16674,
    "text": " You know what."
  },
  {
    "id": 128,
    "speaker": "Ted",
    "start": 374.16674,
    "end": 377.59674,
    "text": " Now go back and enjoy the party."
  },
  {
    "id": 129,
    "speaker": "Ted",
    "start": 378.43674,
    "end": 379.27673,
    "text": " Sorry."
  },
  {
    "id": 130,
    "speaker": "Peggy",
    "start": 380.17673,
    "end": 382.57672,
    "text": " I grew up here."
  },
  {
    "id": 131,
    "speaker": "Ted",
    "start": 384.05673,
    "end": 386.09674,
    "text": " Who didn't?"
  },
  {
    "id": 132,
    "speaker": "Peggy",
    "start": 387.2567,
    "end": 389.77673,
    "text": " To just pick up stakes."
  },
  {
    "id": 133,
    "speaker": "Ted",
    "start": 390.67673,
    "end": 391.45673,
    "text": " I know."
  },
  {
    "id": 134,
    "speaker": "Peggy",
    "start": 392.57672,
    "end": 395.65674,
    "text": " I mean, this is where I live."
  },
  {
    "id": 135,
    "speaker": "Ted",
    "start": 396.83673,
    "end": 400.85672,
    "text": " Me too. We'll just have to behave ourselves then."
  },
  {
    "id": 136,
    "speaker": "Peggy",
    "start": 402.21674,
    "end": 403.33673,
    "text": " Oh, Ted."
  },
  {
    "id": 137,
    "speaker": "Ted",
    "start": 404.27673,
    "end": 406.55673,
    "text": " Be good little children."
  },
  {
    "id": 138,
    "speaker": "Peggy",
    "start": 407.73672,
    "end": 409.73672,
    "text": " Oh, I can't stand it."
  },
  {
    "id": 139,
    "speaker": "Ted",
    "start": 410.61673,
    "end": 415.33673,
    "text": " And if we're seated next to each other, we'll have to make a conscious effort."
  },
  {
    "id": 140,
    "speaker": "Peggy",
    "start": 416.45673,
    "end": 418.91672,
    "text": " Oh, we won't be seated next to each other."
  },
  {
    "id": 141,
    "speaker": "Peggy",
    "start": 419.47675,
    "end": 420.49673,
    "text": " Judy will see to that."
  },
  {
    "id": 142,
    "speaker": "Ted",
    "start": 421.8167,
    "end": 423.19672,
    "text": " For a while, anyway."
  },
  {
    "id": 143,
    "speaker": "Peggy",
    "start": 424.87674,
    "end": 426.71674,
    "text": " For quite a while."
  },
  {
    "id": 144,
    "speaker": "Winkie",
    "start": 428.61673,
    "end": 429.77673,
    "text": " Everyone's finished, Mommy."
  },
  {
    "id": 145,
    "speaker": "Peggy",
    "start": 431.07672,
    "end": 431.87674,
    "text": " Thank you, sweetheart."
  },
  {
    "id": 146,
    "speaker": "Winkie",
    "start": 433.37674,
    "end": 434.3167,
    "text": " And here's your ring."
  },
  {
    "id": 147,
    "speaker": "Winkie",
    "start": 435.07672,
    "end": 435.8167,
    "text": " From the cake."
  },
  {
    "id": 148,
    "speaker": "Peggy",
    "start": 437.01672,
    "end": 438.35672,
    "text": " Good for you, darling."
  },
  {
    "id": 149,
    "speaker": "Peggy",
    "start": 438.49673,
    "end": 439.61673,
    "text": " I forgot all about it."
  },
  {
    "id": 150,
    "speaker": "Ted",
    "start": 440.03674,
    "end": 441.61673,
    "text": " Time to go, then?"
  },
  {
    "id": 151,
    "speaker": "Peggy",
    "start": 442.19672,
    "end": 443.37674,
    "text": " I've planned some games."
  },
  {
    "id": 152,
    "speaker": "Ted",
    "start": 444.57672,
    "end": 445.65674,
    "text": " Want me to stay?"
  },
  {
    "id": 153,
    "speaker": "Peggy",
    "start": 446.19672,
    "end": 446.83673,
    "text": " It would help"
  },
  {
    "id": 154,
    "speaker": "Ted",
    "start": 447.95673,
    "end": 449.33673,
    "text": " Then I'll stay"
  },
  {
    "id": 155,
    "speaker": "Peggy",
    "start": 450.59674,
    "end": 451.76674,
    "text": " Into the living room now, children"
  },
  {
    "id": 156,
    "speaker": "Peggy",
    "start": 451.76674,
    "end": 453.34672,
    "text": " For some games"
  },
  {
    "id": 157,
    "speaker": "Brewster",
    "start": 453.34672,
    "end": 456.13672,
    "text": " What games?"
  },
  {
    "id": 158,
    "speaker": "Peggy",
    "start": 456.69672,
    "end": 457.82673,
    "text": " Oh, all kinds of games"
  },
  {
    "id": 159,
    "speaker": "Peggy",
    "start": 457.82673,
    "end": 459.78674,
    "text": " Blind man's bluff"
  },
  {
    "id": 160,
    "speaker": "Peggy",
    "start": 459.78674,
    "end": 461.47671,
    "text": " Pin the tail on the donkey"
  },
  {
    "id": 161,
    "speaker": "Ted",
    "start": 461.47671,
    "end": 463.41672,
    "text": " I'll get them started"
  },
  {
    "id": 162,
    "speaker": "Peggy",
    "start": 463.41672,
    "end": 465.15674,
    "text": " Would you?"
  },
  {
    "id": 163,
    "speaker": "Peggy",
    "start": 465.93674,
    "end": 467.13673,
    "text": " While I propitiate Roberta"
  },
  {
    "id": 164,
    "speaker": "Ted",
    "start": 467.13673,
    "end": 469.18674,
    "text": " I'll be the donkey"
  },
  {
    "id": 165,
    "speaker": "Peggy",
    "start": 469.18674,
    "end": 471.47675,
    "text": " Oh, stop"
  },
  {
    "id": 166,
    "speaker": "Ted",
    "start": 472.71674,
    "end": 473.51672,
    "text": " I'll be the ass"
  },
  {
    "id": 167,
    "speaker": "Peggy",
    "start": 474.67673,
    "end": 475.89673,
    "text": " Stop or I'll scream"
  },
  {
    "id": 168,
    "speaker": "Winkie",
    "start": 477.17673,
    "end": 477.66674,
    "text": " Come on, Mommy"
  },
  {
    "id": 169,
    "speaker": "Winkie",
    "start": 477.66674,
    "end": 478.99673,
    "text": " We're waiting"
  },
  {
    "id": 170,
    "speaker": "Peggy",
    "start": 480.17673,
    "end": 481.01672,
    "text": " We're coming, dear"
  }
]
